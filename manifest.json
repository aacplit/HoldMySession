{
  "manifest_version": 3,
  "name": "HoldMySession",
  "version": "1.0.1",
  "description": "Reserve your computer while you step away",
  "permissions": ["storage", "windows"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "externally_connectable": {
    "matches": ["https://aacplit.github.io/*"]
  }
}
